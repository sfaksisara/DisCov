def _build_heatmap(agg_per_clf, best_k, metric):
    methods = list(METHODS.keys())
    mat     = np.full((len(methods), len(CLASSIFIER_NAMES)), float('nan'))
    for i, m in enumerate(methods):
        for j, c in enumerate(CLASSIFIER_NAMES):
            row = agg_per_clf[
                (agg_per_clf['method']==m) &
                (agg_per_clf['classifier']==c) &
                (agg_per_clf['k']==best_k)]
            if not row.empty:
                mat[i,j] = row[f'{metric}_mean'].values[0]
    return mat, methods

def _plot_heatmap(agg_per_clf, best_k, metric, cmap, label, fname, plotnum):
    mat, methods = _build_heatmap(agg_per_clf, best_k, metric)
    fig, ax = plt.subplots(figsize=(14, 8))
    fig.set_facecolor(FIG_BG); ax.set_facecolor(FIG_BG)
    vmin = max(0, np.nanmin(mat)-0.02) if metric == 'auc' else np.nanmin(mat)
    vmax = 1.0 if metric == 'auc' else np.nanmax(mat)
    im = ax.imshow(mat, cmap=cmap, aspect='auto', vmin=vmin, vmax=vmax)
    cbar = plt.colorbar(im, ax=ax); cbar.set_label(label, fontsize=10)
    ax.set_xticks(range(len(CLASSIFIER_NAMES)))
    ax.set_xticklabels(CLASSIFIER_NAMES, fontsize=9, rotation=25, ha='right')
    ax.set_yticks(range(len(methods)))
    ax.set_yticklabels(methods, fontsize=10)
    ax.set_title(f'Plot {plotnum} — {label}: method x classifier (k={best_k})',
                 fontsize=13, fontweight='bold')
    mid = (np.nanmin(mat)+np.nanmax(mat))/2
    for i in range(len(methods)):
        for j in range(len(CLASSIFIER_NAMES)):
            if not np.isnan(mat[i,j]):
                ax.text(j, i, f'{mat[i,j]:.3f}', ha='center', va='center',
                        color='white' if mat[i,j] < mid else '#1e293b',
                        fontsize=7.5)
