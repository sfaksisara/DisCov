SCALAR_METRICS = ['accuracy', 'balanced_acc', 'mcc', 'kappa', 'f1_macro', 'auc']

def aggregate(results):
    rows = []
    for method, k_dict in results.items():
        for k, clf_dict in k_dict.items():
            for clf_name in CLASSIFIER_NAMES + ['Average']:
                folds = clf_dict.get(clf_name, [])
                if not folds:
                    continue
                row = {'method': method, 'k': k, 'classifier': clf_name}
                for m in SCALAR_METRICS:
                    vals = [f[m] for f in folds
                            if not np.isnan(f.get(m, float('nan')))]
                    row[f'{m}_mean'] = np.nanmean(vals) if vals else float('nan')
                    row[f'{m}_std']  = np.nanstd(vals)  if vals else float('nan')
                    row[f'{m}_vals'] = vals
                rows.append(row)
    df = pd.DataFrame(rows)
    return (df[df['classifier'] != 'Average'].copy(),
            df[df['classifier'] == 'Average'].copy())


def cohen_d(a, b):
    a, b = np.array(a), np.array(b)
    pooled = np.sqrt((a.std(ddof=1)**2 + b.std(ddof=1)**2)/2) + 1e-8
    return (a.mean() - b.mean()) / pooled


def statistical_tests(results, best_k, clf_name='Average'):
    methods  = list(results.keys())
    al_folds = [f['accuracy'] for f in
                results.get('DiscCov',{}).get(best_k,{}).get(clf_name,[])]
    if not al_folds:
        return pd.DataFrame()

    rows = []; all_acc = []
    for mname in methods:
        vals = [f['accuracy']
                for f in results[mname].get(best_k,{}).get(clf_name,[])]
        if vals:
            all_acc.append(vals)
        if mname == 'DiscCov' or not vals or len(vals) < 3:
            continue
        try:
            _, p_w = wilcoxon(al_folds, vals[:len(al_folds)], alternative='greater')
        except Exception:
            p_w = float('nan')
        rows.append(dict(
            vs=mname, clf=clf_name,
            al_mean=np.mean(al_folds),
            other_mean=np.mean(vals),
            p_value=round(p_w,4) if not np.isnan(p_w) else 'n/a',
            significant='yes' if (not np.isnan(p_w) and p_w < 0.05) else 'no',
            cohen_d=round(cohen_d(al_folds, vals[:len(al_folds)]), 3)
        ))

    if len(all_acc) >= 3:
        min_len = min(len(a) for a in all_acc)
        try:
            stat_f, p_f = friedmanchisquare(*[a[:min_len] for a in all_acc])
        except Exception:
            stat_f, p_f = float('nan'), float('nan')
    else:
        stat_f, p_f = float('nan'), float('nan')

    df = pd.DataFrame(rows)
    df.attrs['friedman_stat'] = round(stat_f,3) if not np.isnan(stat_f) else 'n/a'
    df.attrs['friedman_p']    = round(p_f,4)    if not np.isnan(p_f)    else 'n/a'
    return df


