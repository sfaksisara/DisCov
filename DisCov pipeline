    ax.axvline(0.2, color='#d97706', lw=1, ls='--', alpha=0.7, label='small (0.2)')
    ax.axvline(0.5, color='#ea580c', lw=1, ls='--', alpha=0.7, label='medium (0.5)')
    ax.axvline(0.8, color='#9333ea', lw=1, ls='--', alpha=0.7, label='large (0.8)')
    for bar, val in zip(bars, d_vals):
        ax.text(val + (0.01 if val >= 0 else -0.01),
                bar.get_y()+bar.get_height()/2,
                f'{val:.3f}', va='center',
                ha='left' if val >= 0 else 'right',
                fontsize=9, color=TICK_COL)
    ax.set_xlabel("Cohen's d  (DiscCov vs method, avg 9 clf)", fontsize=11)
    ax.set_title(f"Plot 9 — Effect size: DiscCov vs all methods (k={best_k})",
                 fontsize=13, fontweight='bold')
    _legend(ax)
    plt.tight_layout()
    return _save(fig, 'plot09_effect_size.png')


def plot_multi_metric_grouped(agg_avg, best_k):
    methods = list(METHODS.keys())
    metrics = ['accuracy_mean', 'f1_macro_mean', 'auc_mean']
    labels  = ['Accuracy', 'F1-Macro', 'ROC-AUC']
    colors  = ['#2563eb', '#059669', '#ea580c']
    sub     = agg_avg[agg_avg['k']==best_k]
    x       = np.arange(len(methods))
    width   = 0.26
    fig, ax = plt.subplots(figsize=(16, 6))
    fig.set_facecolor(FIG_BG); _style_ax(ax)
    for si, (metric, label, color) in enumerate(zip(metrics, labels, colors)):
        vals = []; errs = []
        for m in methods:
            row = sub[sub['method']==m]
            vals.append(row[metric].values[0] if not row.empty else 0)
            errs.append(row[metric.replace('_mean','_std')].values[0]
                        if not row.empty else 0)
        offset = (si-1)*width
        ax.bar(x+offset, vals, width, label=label, color=color, alpha=0.85, zorder=3)
        ax.errorbar(x+offset, vals, yerr=errs,
                    fmt='none', color='#1e293b', capsize=3, lw=1.2, zorder=4)
    ax.set_xticks(x)
    ax.set_xticklabels(methods, rotation=30, ha='right', fontsize=9)
    ax.set_ylabel('Score (mean +/- std)', fontsize=11)
    ax.set_title(f'Plot 10 — Accuracy / F1-Macro / ROC-AUC at k={best_k}',
                 fontsize=13, fontweight='bold')
    ax.set_ylim(0, 1.08)
    _legend(ax)
    plt.tight_layout()
    return _save(fig, 'plot10_multi_metric_grouped.png')

