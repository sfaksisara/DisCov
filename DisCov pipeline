def log2_transform(X):
    if np.any(X < 0) or np.nanmax(X) < 30:
        print("  Skipping log2 (data appears already log-transformed).")
        return X
    print("  log2(X+1) transform ...")
    return np.log2(X + 1)

def quantile_normalize(X):
    print("  Quantile normalising ...")
    Xt = X.T
    ranks = np.apply_along_axis(rankdata, 0, Xt)
    row_means = np.sort(Xt, axis=0).mean(axis=1)
    norm = np.zeros_like(Xt, dtype=float)
    for j in range(Xt.shape[1]):
        norm[:, j] = row_means[(ranks[:, j] - 1).astype(int)]
    return norm.T

def preprocess(X, do_log2=True, do_qnorm=True):
    if np.isnan(X).any():
        X = SimpleImputer(strategy='mean').fit_transform(X)
    if do_log2:
        X = log2_transform(X)
    if do_qnorm:
        X = quantile_normalize(X)
    return X

