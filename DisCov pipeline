# SECTION 6 — METHOD CONFIG
# ─────────────────────────────────────────────────────────────────────────────

K_VALUES = [5, 10, 25, 50, 100, 150, 200]

METHODS = {
    'DiscCov':       dict(alpha_fixed=None, beta_fixed=None),
    'AL-fixed':      dict(alpha_fixed=0.5,  beta_fixed=0.5),
    'disc-only':     dict(alpha_fixed=0.0,  beta_fixed=1.0),
    'cov-only':      dict(alpha_fixed=1.0,  beta_fixed=0.0),
    'mRMR':          None,
    't-test':        None,
    'LASSO':         None,
    'ReliefF':       None,
    'RF-importance': None,
    'SVM-RFE':       None,
    'ElasticNet':    None,
    'ANOVA':         None,
}

AL_METHODS     = ['DiscCov', 'AL-fixed', 'disc-only', 'cov-only']
BASELINE_NAMES = ['mRMR', 't-test', 'LASSO', 'ReliefF', 'RF-importance',
                  'SVM-RFE', 'ElasticNet', 'ANOVA']

# ─────────────────────────────────────────────────────────────────────────────
# SECTION 7 — MAIN CV LOOP
# ─────────────────────────────────────────────────────────────────────────────

def run_pipeline(X, y, n_folds=5, random_state=42, verbose=True):
    classes = np.unique(y)
    skf     = StratifiedKFold(n_splits=n_folds, shuffle=True,
                              random_state=random_state)
    results = defaultdict(lambda: defaultdict(lambda: defaultdict(list)))
    ab_log  = defaultdict(list)
    max_k   = max(K_VALUES)

    for fold_i, (tr_idx, te_idx) in enumerate(skf.split(X, y)):
        X_tr, X_te = X[tr_idx], X[te_idx]
        y_tr, y_te = y[tr_idx], y[te_idx]

        for mname in AL_METHODS:
            cfg = METHODS[mname]
            sel = ALGeneSelector(
                n_genes=max_k,
                alpha_fixed=cfg['alpha_fixed'],
                beta_fixed=cfg['beta_fixed'],
                random_state=random_state + fold_i)
            sel.fit(X_tr, y_tr)

            if mname == 'DiscCov':
                ab_log[fold_i].append(
                    list(zip(sel.alpha_history_, sel.beta_history_)))

            for k in K_VALUES:
                k_eff  = min(k, len(sel.selected_indices_))
                X_tr_k = sel.transform(X_tr, k_eff)
                X_te_k = sel.transform(X_te, k_eff)
                n_pca  = min(k_eff, X_tr_k.shape[0]-1, 30)
                if n_pca > 1 and k_eff > n_pca:
                    pca    = PCA(n_components=n_pca, random_state=random_state)
                    X_tr_k = pca.fit_transform(X_tr_k)
                    X_te_k = pca.transform(X_te_k)
                clf_res = evaluate_gene_subset(
                    X_tr_k, y_tr, X_te_k, y_te, classes,
                    random_state=random_state+fold_i)
                for clf_name, m in clf_res.items():
                    m_copy = dict(m)
                    m_copy.update(k=k, fold=fold_i+1, method=mname)
                    results[mname][k][clf_name].append(m_copy)

        for bname in BASELINE_NAMES:
            for k in K_VALUES:
                k_eff = min(k, X_tr.shape[1])
                try:
                    gene_idx = get_baseline_genes(
                        bname, X_tr, y_tr, k_eff,
                        random_state=random_state+fold_i)
                except Exception as e:
                    if verbose:
                        print(f"  [WARN] {bname} k={k} fold={fold_i+1}: {e}")
                    continue
                X_tr_k = X_tr[:, gene_idx]
                X_te_k = X_te[:, gene_idx]
                n_pca  = min(k_eff, X_tr_k.shape[0]-1, 30)
                if n_pca > 1 and k_eff > n_pca:
                    pca    = PCA(n_components=n_pca, random_state=random_state)
                    X_tr_k = pca.fit_transform(X_tr_k)
                    X_te_k = pca.transform(X_te_k)
                clf_res = evaluate_gene_subset(
                    X_tr_k, y_tr, X_te_k, y_te, classes,
                    random_state=random_state+fold_i)
                for clf_name, m in clf_res.items():
                    m_copy = dict(m)
                    m_copy.update(k=k, fold=fold_i+1, method=bname)
                    results[bname][k][clf_name].append(m_copy)

        if verbose:
            print(f"  Fold {fold_i+1}/{n_folds} done")

    return results, ab_log, classes

