def baseline_ttest_topk(X, y, k):
    return np.argsort(disc_ttest(X, y))[::-1][:k]

def baseline_rf_importance(X, y, k, random_state=42):
    rf = RandomForestClassifier(n_estimators=100, random_state=random_state, n_jobs=-1)
    rf.fit(X, y)
    return np.argsort(rf.feature_importances_)[::-1][:k]

def baseline_lasso(X, y, k, random_state=42):
    try:
        lasso = LassoCV(cv=3, random_state=random_state, max_iter=5000,
                        n_jobs=-1).fit(X, y.astype(float))
        idx = np.argsort(np.abs(lasso.coef_))[::-1][:k]
        if len(idx) < k:
            rest = [i for i in range(X.shape[1]) if i not in set(idx)]
            idx  = np.concatenate([idx, rest[:k-len(idx)]])
        return idx[:k]
    except Exception:
        return baseline_ttest_topk(X, y, k)

def baseline_relieff(X, y, k, n_neighbors=5, max_samples=50):
    classes = np.unique(y)
    weights = np.zeros(X.shape[1])
    rng = np.random.default_rng(42)
    sample_idx = rng.choice(X.shape[0], size=min(max_samples, X.shape[0]),
                            replace=False)
    for i in sample_idx:
        xi = X[i]; ci = y[i]
        same = np.where(y==ci)[0]; same = same[same!=i]
        if len(same) == 0: continue
        hits = same[np.argsort(np.sum((X[same]-xi)**2,axis=1))[:n_neighbors]]
        misses_all = []
        for cls in classes:
            if cls==ci: continue
            diff = np.where(y==cls)[0]
            if len(diff)==0: continue
            misses_all.append(
                X[diff[np.argsort(np.sum((X[diff]-xi)**2,axis=1))[:n_neighbors]]])
        if not misses_all: continue
        X_miss = np.vstack(misses_all)
        weights -= np.mean(np.abs(X[hits]-xi), axis=0) / len(sample_idx)
        weights += np.mean(np.abs(X_miss-xi),  axis=0) / len(sample_idx)
    return np.argsort(weights)[::-1][:k]

def baseline_mrmr(X, y, k):
    y_f = y.astype(float); y_c = y_f - y_f.mean()
    yn  = np.linalg.norm(y_c) + 1e-8
    relevance = np.array([
        abs(np.dot(X[:,j]-X[:,j].mean(), y_c) /
            (np.linalg.norm(X[:,j]-X[:,j].mean())*yn + 1e-8))
        for j in range(X.shape[1])
    ])
    Xs = X - X.mean(0); norms = np.linalg.norm(Xs, axis=0)+1e-8
    corr_matrix = np.abs((Xs/norms).T @ (Xs/norms)) / X.shape[0]
    selected = []; remaining = list(range(X.shape[1]))
    for _ in range(k):
        if not selected:
            best = remaining[int(np.argmax(relevance[remaining]))]
        else:
            redundancy = np.array([corr_matrix[j,selected].mean() for j in remaining])
            best = remaining[int(np.argmax(relevance[remaining] - redundancy))]
        selected.append(best); remaining.remove(best)
    return np.array(selected)

def baseline_svm_rfe(X, y, k, random_state=42):
    try:
        estimator = LinearSVC(random_state=random_state, max_iter=5000, C=1.0)
        step = max(1, (X.shape[1]-k)//20)
        rfe  = RFE(estimator=estimator, n_features_to_select=k, step=step)
        rfe.fit(X, y)
        return np.where(rfe.support_)[0][:k]
    except Exception:
        return baseline_ttest_topk(X, y, k)

def baseline_elasticnet(X, y, k, random_state=42):
    try:
        en = ElasticNet(alpha=0.01, l1_ratio=0.5, max_iter=5000,
                        random_state=random_state)
        en.fit(X, y.astype(float))
        idx = np.argsort(np.abs(en.coef_))[::-1][:k]
        if len(idx) < k:
            rest = [i for i in range(X.shape[1]) if i not in set(idx)]
            idx  = np.concatenate([idx, rest[:k-len(idx)]])
        return idx[:k]
    except Exception:
        return baseline_ttest_topk(X, y, k)

def baseline_anova_ftest(X, y, k):
    try:
        sel = SelectKBest(score_func=f_classif, k=min(k, X.shape[1]))
        sel.fit(X, y)
        return np.argsort(sel.scores_)[::-1][:k]
    except Exception:
        return baseline_ttest_topk(X, y, k)

def get_baseline_genes(name, X, y, k, random_state=42):
    if name == 't-test':        return baseline_ttest_topk(X, y, k)
    if name == 'RF-importance': return baseline_rf_importance(X, y, k, random_state)
    if name == 'LASSO':         return baseline_lasso(X, y, k, random_state)
    if name == 'ReliefF':       return baseline_relieff(X, y, k)
    if name == 'mRMR':          return baseline_mrmr(X, y, k)
    if name == 'SVM-RFE':       return baseline_svm_rfe(X, y, k, random_state)
    if name == 'ElasticNet':    return baseline_elasticnet(X, y, k, random_state)
    if name == 'ANOVA':         return baseline_anova_ftest(X, y, k)
    return baseline_ttest_topk(X, y, k)

