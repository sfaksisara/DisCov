def _minmax(arr):
    r = arr - arr.min()
    return r / r.max() if r.max() > 0 else r

def disc_snr(X, y):
    classes = np.unique(y)
    best = np.zeros(X.shape[1])
    for i, j in combinations(range(len(classes)), 2):
        m1 = X[y==classes[i]].mean(0); s1 = X[y==classes[i]].std(0)+1e-8
        m2 = X[y==classes[j]].mean(0); s2 = X[y==classes[j]].std(0)+1e-8
        best = np.maximum(best, np.abs((m1-m2)/(s1+s2)))
    return _minmax(best)

def disc_ttest(X, y):
    classes = np.unique(y)
    best = np.zeros(X.shape[1])
    for cls in classes:
        mask = y == cls
        if mask.sum() < 2 or (~mask).sum() < 2:
            continue
        m1, m2 = X[mask].mean(0), X[~mask].mean(0)
        v1 = X[mask].var(0, ddof=1)/mask.sum() + 1e-8
        v2 = X[~mask].var(0, ddof=1)/(~mask).sum() + 1e-8
        t  = np.abs((m1-m2)/np.sqrt(v1+v2))
        best = np.maximum(best, np.nan_to_num(t))
    return _minmax(best)

def disc_anova(X, y):
    classes = np.unique(y)
    groups  = [X[y==c] for c in classes if (y==c).sum() >= 2]
    if len(groups) < 2:
        return np.zeros(X.shape[1])
    grand_mean = X.mean(0)
    k = len(groups); n_total = X.shape[0]
    ssbw = sum(len(g)*(g.mean(0)-grand_mean)**2 for g in groups)
    ssw  = sum(((g-g.mean(0))**2).sum(0) for g in groups)
    f = (ssbw/(k-1)) / (ssw/(n_total-k) + 1e-8)
    return _minmax(np.nan_to_num(f))

# ── CHANGE 1: rank aggregation instead of raw sum ────────────────────────────
def disc_combined(X, y):
    s1 = disc_snr(X, y)
    s2 = disc_ttest(X, y)
    s3 = disc_anova(X, y)
    n  = len(s1)
    r1 = rankdata(s1) / n
    r2 = rankdata(s2) / n
    r3 = rankdata(s3) / n
    return _minmax(r1 + r2 + r3)

