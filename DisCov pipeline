def build_classifiers(random_state=42):
    lr  = LogisticRegression(max_iter=1000, random_state=random_state, n_jobs=-1)
    rf  = RandomForestClassifier(n_estimators=100, random_state=random_state, n_jobs=-1)
    svm = SVC(kernel='linear', probability=True, C=1.0, random_state=random_state)

    voting = VotingClassifier(
        estimators=[
            ('lr',  LogisticRegression(max_iter=1000, random_state=random_state)),
            ('rf',  RandomForestClassifier(n_estimators=100, random_state=random_state)),
            ('svm', SVC(kernel='linear', probability=True, C=1.0,
                        random_state=random_state))],
        voting='soft', n_jobs=-1)

    stacking = StackingClassifier(
        estimators=[
            ('lr',  LogisticRegression(max_iter=1000, random_state=random_state)),
            ('rf',  RandomForestClassifier(n_estimators=100, random_state=random_state)),
            ('svm', SVC(kernel='linear', probability=True, C=1.0,
                        random_state=random_state))],
        final_estimator=LogisticRegression(max_iter=1000, random_state=random_state),
        cv=3, n_jobs=-1)

    return {
        'LogisticRegression': lr,
        'RandomForest':       rf,
        'SVM':                svm,
        'LDA':                LinearDiscriminantAnalysis(),
        'KNN':                KNeighborsClassifier(n_neighbors=5, metric='euclidean'),
        'GradientBoosting':   GradientBoostingClassifier(
                                  n_estimators=100, learning_rate=0.1,
                                  random_state=random_state),
        'AdaBoost':           AdaBoostClassifier(
                                  n_estimators=50, learning_rate=1.0,
                                  random_state=random_state),
        'VotingEnsemble':     voting,
        'StackingEnsemble':   stacking,
    }


def compute_metrics(y_true, y_pred, y_prob, classes):
    n_cls    = len(classes)
    acc      = accuracy_score(y_true, y_pred)
    bacc     = balanced_accuracy_score(y_true, y_pred)
    mcc      = matthews_corrcoef(y_true, y_pred)
    kappa    = cohen_kappa_score(y_true, y_pred)
    f1_macro = f1_score(y_true, y_pred, average='macro', zero_division=0)
    f1_per   = f1_score(y_true, y_pred, average=None,    zero_division=0,
                        labels=classes)
    try:
        if n_cls == 2:
            auc = roc_auc_score(y_true, y_prob[:, 1])
        else:
            auc = roc_auc_score(
                label_binarize(y_true, classes=classes),
                y_prob, multi_class='ovr', average='macro')
    except Exception:
        auc = float('nan')
    cm = confusion_matrix(y_true, y_pred, labels=classes)
    return dict(accuracy=acc, balanced_acc=bacc, mcc=mcc, kappa=kappa,
                f1_macro=f1_macro, f1_per_class=f1_per, auc=auc, cm=cm)


def evaluate_gene_subset(X_tr_k, y_tr, X_te_k, y_te, classes, random_state=42):
    SCALAR  = ['accuracy', 'balanced_acc', 'mcc', 'kappa', 'f1_macro', 'auc']
    clfs    = build_classifiers(random_state)
    all_res = {}
    for clf_name, clf in clfs.items():
        try:
            clf.fit(X_tr_k, y_tr)
            y_pred = clf.predict(X_te_k)
            y_prob = clf.predict_proba(X_te_k)
            m = compute_metrics(y_te, y_pred, y_prob, classes)
        except Exception:
            m = {s: float('nan') for s in SCALAR}
            m.update(f1_per_class=np.zeros(len(classes)),
                     cm=np.zeros((len(classes), len(classes))))
        m['clf'] = clf_name
        all_res[clf_name] = m
    avg = {s: np.nanmean([all_res[cn][s] for cn in CLASSIFIER_NAMES])
           for s in SCALAR}
    avg['clf'] = 'Average'
    avg['f1_per_class'] = np.nanmean(
        [all_res[cn]['f1_per_class'] for cn in CLASSIFIER_NAMES], axis=0)
    avg['cm'] = np.nanmean(
        [all_res[cn]['cm'] for cn in CLASSIFIER_NAMES], axis=0)
    all_res['Average'] = avg
    return all_res

