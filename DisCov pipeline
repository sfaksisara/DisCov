# SECTION 3 — AL GENE SELECTOR  (v4 — five targeted fixes)
# ─────────────────────────────────────────────────────────────────────────────

class ALGeneSelector:
    def __init__(self, n_genes=50, disc_method='combined',
                 alpha_fixed=None, beta_fixed=None, random_state=42):
        self.n_genes      = n_genes
        self.disc_method  = disc_method
        self.alpha_fixed  = alpha_fixed
        self.beta_fixed   = beta_fixed
        self.random_state = random_state
        self.selected_indices_ = []
        self.alpha_history_    = []
        self.beta_history_     = []
        self._y = None   # stored in fit() for class-conditioned coverage

    def _disc_scores(self, X, y):
        if self.disc_method == 'snr':   return disc_snr(X, y)
        if self.disc_method == 'ttest': return disc_ttest(X, y)
        if self.disc_method == 'anova': return disc_anova(X, y)
        return disc_combined(X, y)

    def _reliability(self, disc_scores):
        return min(1.0, (disc_scores.max()-disc_scores.min()) / 0.5)

    def _gap(self, X, y, selected):
        if not selected:
            return 1.0
        X_sel = X[:, selected]
        y_f = y.astype(float); y_c = y_f - y_f.mean()
        corrs = []
        for j in range(X_sel.shape[1]):
            x_c = X_sel[:,j] - X_sel[:,j].mean()
            denom = np.linalg.norm(x_c)*np.linalg.norm(y_c) + 1e-8
            corrs.append(abs(np.dot(x_c, y_c)/denom))
        return max(0.0, 1.0 - np.mean(corrs))

    # ── CHANGE 2: dataset-size-aware beta decay + hard floor after k=25 ────────
    def _adaptive_weights(self, disc_scores, X, y, selected):
        r = self._reliability(disc_scores)
        g = self._gap(X, y, selected)
        if self.beta_fixed is not None:
            beta  = float(self.beta_fixed)
            alpha = 1.0 - beta
        elif self.alpha_fixed is not None:
            alpha = float(self.alpha_fixed)
            beta  = 1.0 - alpha
        else:
            # decay_rate scales with n: small datasets ~0.30, large ~0.50
            n_samples  = len(self._y) if self._y is not None else 100
            decay_rate = 0.30 + 0.20 * min(1.0, n_samples / 200.0)
            progress   = len(selected) / max(1, self.n_genes)
            beta_base  = 0.80 - decay_rate * progress
            beta       = min(beta_base, BASE_BETA * r + 0.15 * g)
            alpha      = max(1.0 - beta, ALPHA_MIN)
            # After first 25 genes coverage has done its job:
            # force disc weight >= 0.70 for all subsequent selections
            if len(selected) >= 25:
                beta  = max(beta, 0.70)
                alpha = 1.0 - beta
        return alpha, beta

    # ── CHANGE 3: class-conditioned coverage (partial correlation) ────────────
    def _coverage_scores(self, X, candidate_indices, selected_indices):
        if not selected_indices:
            return np.ones(len(candidate_indices))
        X_cand = X[:, candidate_indices]
        X_sel  = X[:, selected_indices]
        # Remove within-class means to get class-conditioned residuals
        X_cand_res = X_cand.copy()
        X_sel_res  = X_sel.copy()
        if self._y is not None:
            for cls in np.unique(self._y):
                mask = self._y == cls
                X_cand_res[mask] -= X_cand[mask].mean(0)
                X_sel_res[mask]  -= X_sel[mask].mean(0)
        def _std(M):
            return M / (np.linalg.norm(M, axis=0) + 1e-8)
        corr = np.abs(_std(X_cand_res).T @ _std(X_sel_res)) / X_cand_res.shape[0]
        return _minmax(1.0 - corr.max(axis=1))

    def fit(self, X, y):
        self._y       = y              # CHANGE 3: store for class-conditioned coverage
        n_select      = min(self.n_genes, X.shape[1])
        remaining     = list(range(X.shape[1]))
        selected      = []
        self.selected_indices_ = []
        self.alpha_history_    = []
        self.beta_history_     = []

        for _ in range(n_select):
            disc  = self._disc_scores(X[:, remaining], y)
            cov   = self._coverage_scores(X, remaining, selected)
            alpha, beta = self._adaptive_weights(disc, X, y, selected)
            score = alpha * cov + beta * disc
            score += np.random.default_rng(
                self.random_state + len(selected)).normal(0, 1e-6, len(score))

            # ── CHANGE 4: adaptive disc floor — 25th pct early, median late ──
            # Early selections (k<=25): allow some diversity via loose floor
            # Later selections (k>25):  strict median floor, signal-driven only
            pct        = 50 if len(selected) >= 25 else 25
            disc_floor = np.percentile(disc, pct)
            score[disc < disc_floor] = -np.inf

            best_global = remaining[int(np.argmax(score))]
            selected.append(best_global)
            remaining.remove(best_global)
            self.selected_indices_.append(best_global)
            self.alpha_history_.append(round(alpha, 4))
            self.beta_history_.append(round(beta,  4))

        # ── CHANGE 5: SVM re-ranking — dual index lists ──────────────────────
        # al_indices_   : original AL greedy order  -> used when k <= 25
        # selected_indices_: SVM-reranked order     -> used when k >  25
        # Split avoids noisy SVM weights on tiny gene sets (k=5,10,25)
        # while keeping boundary-aware ordering for larger subsets.
        self.al_indices_ = list(self.selected_indices_)   # freeze AL order
        try:
            X_sel     = X[:, self.selected_indices_]
            svm       = LinearSVC(C=1.0, max_iter=3000,
                                  random_state=self.random_state)
            svm.fit(X_sel, y)
            svm_order = np.argsort(np.abs(svm.coef_[0]))[::-1]
            self.selected_indices_ = [
                self.selected_indices_[i] for i in svm_order]
        except Exception:
            pass    # keep AL order as fallback

        return self

    def transform(self, X, k=None):
        n = k if k is not None else len(self.selected_indices_)
        # AL order for small k (SVM weights unreliable on few genes)
        # SVM-reranked order for larger k (boundary-aware)
        idx = self.al_indices_[:n] if n <= 25 else self.selected_indices_[:n]
        return X[:, idx]

