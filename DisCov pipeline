def main():
    print("="*70)
    print("AL-INSPIRED ADAPTIVE GENE SELECTION PIPELINE (v4.3)")
    print(f"  {len(METHODS)} feature-selection methods  x  "
          f"{len(CLASSIFIER_NAMES)} classifiers  x  "
          f"{len(K_VALUES)} k values  x  5-fold CV")
    print("="*70)

    print("\n[1] Loading data ...")
    try:
        df = pd.read_csv("prostate.csv")
        print(f"  Loaded: {df.shape}")
    except FileNotFoundError:
        print("  File not found — generating synthetic data ...")
        rng = np.random.default_rng(42)
        n_s, n_g = 72, 7129
        X_raw = rng.exponential(scale=500, size=(n_s, n_g)).astype(float)
        y_raw = rng.integers(0, 2, size=n_s)
        X_raw[y_raw==1, :200] += rng.normal(400, 60, (y_raw.sum(), 200))
        df = pd.DataFrame(X_raw); df['label'] = y_raw
        df.to_csv("prostate.csv", index=False)

    X_raw = df.iloc[:,:-1].values.astype(float)
    y_raw = df.iloc[:,-1].values
    y = LabelEncoder().fit_transform(y_raw) if y_raw.dtype.kind not in 'biu' \
        else y_raw.astype(int)
    if y.min() < 0:
        uq = np.unique(y); y = np.array([np.where(uq==v)[0][0] for v in y])
    print(f"  Classes: {np.unique(y)}  Distribution: {np.bincount(y)}")

    print("\n[2] Preprocessing ...")
    X = preprocess(X_raw.copy(), do_log2=True, do_qnorm=True)
    if X.shape[1] > 2000:
        X = X[:, np.argsort(np.var(X, axis=0))[::-1][:2000]]
        print("  Variance pre-filter: kept top 2000 genes")
    print(f"  Shape after preprocessing: {X.shape}")

    print(f"\n[3] Running 5-fold CV ...")
    t0 = time.time()
    results, ab_log, classes = run_pipeline(
        X, y, n_folds=10, random_state=42, verbose=True)
    print(f"  Total time: {time.time()-t0:.1f}s")

    print("\n[4] Aggregating ...")
    agg_per_clf, agg_avg = aggregate(results)
    al_sub = agg_avg[agg_avg['method']=='DiscCov']
    best_k = int(al_sub.loc[al_sub['accuracy_mean'].idxmax(), 'k']) \
             if not al_sub.empty else 100
    print(f"  Best k (DiscCov, avg clf): {best_k}")
    print_summary(agg_per_clf, agg_avg, results, best_k)

    agg_per_clf.to_csv(OUT_DIR+'results_per_classifier.csv', index=False)
    agg_avg.to_csv(    OUT_DIR+'results_averaged.csv',       index=False)
    stat_df = statistical_tests(results, best_k, 'Average')
    if not stat_df.empty:
        stat_df.to_csv(OUT_DIR+'statistical_tests.csv', index=False)
    print(f"\n  CSVs saved to {OUT_DIR}")

    print("\n[5] Generating 10 plots ...")
    plot_accuracy_f1_vs_k(agg_avg)
    plot_auc_vs_k(agg_avg)
    plot_heatmap_accuracy(agg_per_clf, best_k)
    plot_heatmap_f1(agg_per_clf, best_k)
    plot_heatmap_auc(agg_per_clf, best_k)
    plot_best_metrics_bar(agg_avg)
    plot_boxplot_three_metrics(results, best_k)
    plot_clf_comparison(agg_per_clf, best_k)
    plot_effect_size(results, best_k)
    plot_multi_metric_grouped(agg_avg, best_k)

    print("\n" + "="*70)
    print("DONE — all outputs in", OUT_DIR)
    print("="*70)


if __name__ == "__main__":
    main() 
